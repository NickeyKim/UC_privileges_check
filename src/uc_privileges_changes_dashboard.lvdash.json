{
  "datasets": [
    {
      "name": "a59a7686",
      "displayName": "today_added_grant",
      "queryLines": [
        "-- Today ADDED\n",
        "SELECT count(*) AS cnt\n",
        "FROM users.nakhoe_kim.uc_grants_drift\n",
        "WHERE drift_date = current_date()\n",
        "  AND change_type = 'ADDED';\n"
      ]
    },
    {
      "name": "a83c4ba2",
      "displayName": "today_removed_grant",
      "queryLines": [
        "-- Today REMOVED\n",
        "SELECT count(*) AS cnt\n",
        "FROM users.nakhoe_kim.uc_grants_drift\n",
        "WHERE drift_date = current_date()\n",
        "  AND change_type = 'REMOVED';\n"
      ]
    },
    {
      "name": "e6caf288",
      "displayName": "today_changed_summary_grant",
      "queryLines": [
        "SELECT\n",
        "  change_type,\n",
        "  env,\n",
        "  object_type,\n",
        "  object_full_name,\n",
        "  principal,\n",
        "  privilege\n",
        "FROM users.nakhoe_kim.uc_grants_drift\n",
        "WHERE drift_date = current_date()\n",
        "ORDER BY env, change_type, privilege DESC;"
      ]
